# ============================================================================
# FastTest Live Monitoring & Analytics Dashboard - Environment Configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ============================================================================

# --- Runtime ---------------------------------------------------------------
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Database --------------------------------------------------------------
# Local dev / test default is SQLite (zero external dependency).
# For production use PostgreSQL, e.g.:
#   DATABASE_URL="postgresql://user:pass@localhost:5432/fasttest?schema=public"
# and set PRISMA_PROVIDER=postgresql (see prisma/schema.prisma note).
DATABASE_URL="file:./dev.db"

# --- Security --------------------------------------------------------------
# 32-byte key, hex or base64 encoded, used for AES-256-GCM secret encryption.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS_0000000000000000000000000000000000000000000000
# Session signing secret. Generate with the same command.
SESSION_SECRET=CHANGE_ME_SESSION_SECRET
# Cookie security: set to true behind HTTPS in production.
SESSION_SECURE_COOKIE=false
# Session idle lifetime in milliseconds (default 1 hour).
SESSION_MAX_AGE_MS=3600000

# --- Bootstrap admin (created by seed if not present) ----------------------
BOOTSTRAP_ADMIN_EMAIL=admin@fasttest.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe!Admin123

# --- FastTest API ----------------------------------------------------------
FASTTEST_BASE_URL=https://uae.fasttestweb.com/FastTest/api
FASTTEST_AUTH_USERNAME=
FASTTEST_AUTH_PASSWORD=
FASTTEST_TOKEN_TTL_SECONDS=3600
# Refresh a cached token this many seconds BEFORE it actually expires.
FASTTEST_TOKEN_REFRESH_MARGIN_SECONDS=300
FASTTEST_REQUEST_TIMEOUT_MS=15000

# --- Per-subject REST API keys (used by seed to bootstrap workspaces) ------
# These are seeded into the DB ENCRYPTED. Leave blank to configure later in
# the Integration Settings admin UI. Never hardcode these in source.
FASTTEST_KEY_ARABIC=
FASTTEST_KEY_ENGLISH=
FASTTEST_KEY_MATH=
FASTTEST_KEY_SCIENCE=

# --- Sync worker (durable queue, Phase 3) ----------------------------------
SYNC_ENABLED=true
SYNC_WORKER_CONCURRENCY=20
SYNC_TICK_INTERVAL_MS=15000
SYNC_MAX_BATCH=50
FASTTEST_RATE_LIMIT_PER_MINUTE=300
SYNC_MAX_RETRIES=3
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MS=30000
SYNC_JOB_LOCK_TTL_MS=60000
SYNC_STALLED_JOB_MS=120000
WORKER_HEARTBEAT_MS=10000
WORKER_STALE_MS=30000
SYNC_GLOBAL_MAX_CONCURRENT=60

# --- Per-workspace rate limiting (conservative; FastTest limits NOT assumed) -
RATE_MAX_RPS=8
RATE_MAX_RPM=300
RATE_MAX_CONCURRENT=10
RATE_MIN_DELAY_MS=50
RATE_BURST=15
RATE_COOLDOWN_MS=30000

# --- Adaptive throttling ---------------------------------------------------
ADAPTIVE_ENABLED=true
ADAPTIVE_LATENCY_MS=4000
ADAPTIVE_ERROR_RATE=0.2
ADAPTIVE_RECOVER_MS=60000
ADAPTIVE_MIN_THROTTLE=0.25

# --- Circuit breaker (per workspace) ---------------------------------------
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_TIMEOUT_THRESHOLD=3
CIRCUIT_AUTH_THRESHOLD=3
CIRCUIT_OPEN_MS=60000
CIRCUIT_HALFOPEN_PROBES=2

# --- Retention (days; active incidents/unresolved alerts never deleted) ----
RETENTION_API_LOGS_DAYS=90
RETENTION_COMPLETED_JOBS_DAYS=30
RETENTION_FAILED_JOBS_DAYS=180
RETENTION_HEARTBEAT_DAYS=30
RETENTION_METRICS_DAYS=90
RETENTION_AUDIT_DAYS=365

# --- Observability ---------------------------------------------------------
# Token to protect GET /metrics (blank = open; set in production).
METRICS_TOKEN=

# --- Load testing module (DISABLED by default; never enable in prod) -------
LOAD_TEST_ENABLED=false
