<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>FastTest — Live Overview</title>
  <style>
    :root{
      --plane:#0a0f1a; --surface:#141c2e; --line:#26324a;
      --ink:#ffffff; --muted:#c3c2b7; --dim:#8a897f;
      --c-completed:#22c55e; --c-inprogress:#f59e0b; --c-notstarted:#3b82f6; --c-notsynced:#6b7280;
      --good:#22c55e; --warn:#f59e0b; --bad:#ef4444;
    }
    *{box-sizing:border-box;margin:0;padding:0}
    html,body{height:100%}
    body{background:radial-gradient(1200px 700px at 15% -10%, #16213a 0%, var(--plane) 55%);color:var(--ink);
      font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;overflow:hidden;
      display:flex;flex-direction:column;height:100vh;padding:16px;gap:14px}
    .muted{color:var(--muted)} .dim{color:var(--dim)}
    /* header */
    header{display:flex;align-items:center;gap:12px;flex:0 0 auto}
    header .brand{font-size:20px;font-weight:800;letter-spacing:.3px;white-space:nowrap;flex:0 0 auto}
    header .brand small{white-space:nowrap}
    header .brand .dot{display:inline-block;width:10px;height:10px;border-radius:50%;background:var(--good);margin-right:8px;box-shadow:0 0 10px var(--good);animation:pulse 2s infinite}
    @keyframes pulse{0%,100%{opacity:1}50%{opacity:.35}}
    header .spacer{flex:1}
    .pill{padding:6px 13px;border-radius:999px;font-size:13px;font-weight:600;border:1px solid var(--line);background:var(--surface);white-space:nowrap}
    .pill.on{color:var(--good);border-color:#22c55e55} .pill.off{color:var(--dim)}
    .pill.fast{color:var(--warn);border-color:#f59e0b55}
    #clock{font-variant-numeric:tabular-nums;font-size:20px;font-weight:700}
    /* ---- BENTO BOARD ---- */
    .board{flex:1 1 auto;display:grid;gap:14px;min-height:0;
      grid-template-columns:repeat(12,1fr);
      grid-template-rows:1.15fr 1fr 1.2fr;
      grid-template-areas:
        "hero hero hero hero ring ring ring status status status status status"
        "today today today today today subj subj subj subj grade grade grade"
        "part part part part velo velo velo feed feed feed feed feed";}
    .tile{position:relative;overflow:hidden;min-height:0;display:flex;flex-direction:column;
      background:linear-gradient(160deg,#1a2338 0%,#131a2b 100%);border:1px solid var(--line);border-radius:20px;padding:14px 18px;
      box-shadow:0 1px 2px rgba(0,0,0,.3),0 18px 40px -22px rgba(0,0,0,.9), inset 0 0 0 1px rgba(255,255,255,.03)}
    .tile .label{font-size:12px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.6px}
    .tile .val{font-weight:800;line-height:1;font-variant-numeric:tabular-nums;letter-spacing:-1px}
    .tile .sub{font-size:13px;color:var(--dim);margin-top:6px}
    .tile .cap{font-size:13px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:12px;flex:0 0 auto}
    /* accent bar on top */
    .tile::after{content:"";position:absolute;left:0;top:0;width:100%;height:4px;background:var(--accent,transparent);opacity:.7}
    .a-total{--accent:linear-gradient(90deg,#38bdf8,#818cf8)}
    .a-completed{--accent:var(--c-completed)} .a-inprogress{--accent:var(--c-inprogress)}
    .a-synced{--accent:var(--c-notstarted)}
    /* hero (completed) — compact single-row now */
    .hero{grid-area:hero;justify-content:center;background:linear-gradient(155deg,#15321f 0%,#111c2b 62%)}
    .hero .val{font-size:clamp(36px,4.6vw,68px);color:var(--c-completed)}
    .hero .prog{height:8px;background:#0b1220;border-radius:6px;overflow:hidden;margin-top:10px}
    .hero .prog>span{display:block;height:100%;background:linear-gradient(90deg,#16a34a,#22c55e);border-radius:6px;transition:width .6s ease}
    /* mid tiles */
    .ring{grid-area:ring} .status{grid-area:status} .subj{grid-area:subj} .today{grid-area:today} .grade{grid-area:grade}
    .velo{grid-area:velo} .feed{grid-area:feed}
    /* participation coverage panel */
    .part{grid-area:part;overflow:hidden}
    .part .prow:last-of-type{padding-bottom:2px}
    .part .sub{font-size:11.5px;margin-top:auto;padding-top:4px;flex:0 0 auto;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .part .prow{display:flex;align-items:center;gap:12px;padding:6px 0;border-bottom:1px solid #ffffff0d}
    .part .prow:last-of-type{border-bottom:none}
    .part .pico{font-size:20px;flex:0 0 auto}
    .part .pstat .pn{font-size:clamp(18px,1.7vw,24px);font-weight:800;font-variant-numeric:tabular-nums;line-height:1}
    .part .pstat.dim2 .pn{color:var(--muted);font-size:clamp(15px,1.6vw,20px)}
    .part .pstat .pt{font-size:10px;color:var(--dim);margin-top:3px;text-transform:uppercase;letter-spacing:.4px}
    .part .pg{position:relative;width:44px;height:44px;flex:0 0 auto;margin-left:auto}
    .part .pg svg{width:100%;height:100%;transform:rotate(-90deg)}
    .part .pg .g-bg{fill:none;stroke:#26324a;stroke-width:3.4}
    .part .pg .g-fg{fill:none;stroke-width:3.4;stroke-linecap:round;stroke-dasharray:100;stroke-dashoffset:100;transition:stroke-dashoffset .6s ease}
    .part .pg .gpc{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800}
    /* today's activity */
    .today .tlist{overflow-y:auto;display:flex;flex-direction:column;gap:8px;flex:1;min-height:0;margin-top:8px}
    .today .tlist::-webkit-scrollbar{width:6px} .today .tlist::-webkit-scrollbar-thumb{background:#ffffff22;border-radius:3px}
    .today .trow{display:flex;align-items:center;gap:12px;flex-wrap:wrap;padding:6px 0;border-bottom:1px solid #ffffff0d}
    .today .snm{font-weight:700;font-size:14px;min-width:180px;flex:0 0 auto;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:240px}
    .today .stot{background:#22c55e22;color:#86efac;border-radius:20px;padding:2px 10px;font-size:12px;font-weight:800;flex:0 0 auto}
    .today .gchips{display:flex;gap:6px;flex-wrap:wrap}
    .today .gchip{background:var(--surface);border:1px solid var(--line);border-radius:14px;padding:2px 9px;font-size:12px;color:var(--muted)}
    .today .gchip b{color:var(--ink)}
    /* empty states shouldn't leave a big blank card — center them */
    .today .empty{color:var(--dim);font-size:14px;flex:1;display:flex;align-items:center;justify-content:center;text-align:center}
    .feed .empty{color:var(--dim);font-size:13px;flex:1;display:flex;align-items:center;justify-content:center}
    /* live sync feed */
    .feed .flist{overflow:hidden;display:flex;flex-direction:column;flex:1;min-height:0;margin-top:8px}
    .feed .frow{display:grid;grid-template-columns:1fr auto auto;gap:12px;align-items:center;padding:5px 0;border-bottom:1px solid #ffffff0d}
    .feed .frow .code{font-family:ui-monospace,Menlo,monospace;font-weight:700;font-size:14px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .feed .frow .sub{color:var(--dim);font-size:11px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .feed .st{padding:2px 9px;border-radius:20px;font-size:11px;font-weight:700;white-space:nowrap}
    .feed .tm{color:var(--dim);font-size:11px;white-space:nowrap;font-variant-numeric:tabular-nums}
    .st-NOT_SYNCED{background:#6b728022;color:#9ca3af} .st-NOT_STARTED{background:#3b82f622;color:#93c5fd}
    .st-IN_PROGRESS{background:#f59e0b22;color:#fcd34d} .st-COMPLETED{background:#22c55e22;color:#86efac}
    .st-UNDER_REVIEW{background:#a78bfa22;color:#c4b5fd} .st-REVIEW_FAILED{background:#ef444422;color:#fca5a5}
    .st-UNKNOWN{background:#64748b22;color:#cbd5e1}
    /* center small KPI content so tall cards don't leave dead space */
    .tot,.prog-t{justify-content:center}
    /* hero completion trend sparkline (compact) */
    .hero .spark{width:100%;height:30px;display:block;margin-top:8px}
    /* daily velocity mini-bars */
    .velo .cap .peak{float:right;font-weight:800;color:var(--dim);text-transform:none;letter-spacing:0}
    .velo .bars{display:flex;align-items:flex-end;gap:3px;flex:1;height:100%;margin-top:6px;min-height:0;
      border-bottom:1px solid #ffffff14}
    .velo .b{flex:1;min-width:0;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;gap:3px;height:100%;position:relative}
    .velo .b .bar{width:100%;background:linear-gradient(180deg,#4ade80,#16a34a);border-radius:3px 3px 0 0;min-height:2px;transition:height .35s ease}
    /* off-hours (no activity) fade back so the working window stands out */
    .velo .b.zero .bar{background:#ffffff12}
    .velo .b.top .bar{background:linear-gradient(180deg,#86efac,#22c55e);box-shadow:0 0 12px #22c55e55}
    .velo .b .bv{position:absolute;top:0;font-size:9.5px;font-weight:800;color:#86efac;font-variant-numeric:tabular-nums;white-space:nowrap}
    .velo .b .bl{flex:0 0 auto;font-size:9px;color:var(--dim);white-space:nowrap;font-variant-numeric:tabular-nums;padding-top:3px}
    .kpi-val{font-size:clamp(30px,4.2vw,58px);margin-top:auto}
    .tot .val,.prog-t .val,.synced .val{font-size:clamp(28px,3.6vw,50px)}
    .prog-t .val{color:var(--c-inprogress)} .synced .val{color:var(--c-notstarted)}
    /* status segmented bar */
    .segbar{height:40px;border-radius:10px;display:flex;overflow:hidden;background:var(--plane);gap:2px;flex:0 0 auto}
    .segbar > div{transition:width .6s ease;min-width:2px}
    .seg-legend{display:grid;grid-template-columns:repeat(2,1fr);gap:9px 18px;margin-top:16px}
    .seg-legend .row{display:flex;align-items:center;gap:9px}
    .seg-legend .sw{width:13px;height:13px;border-radius:4px;flex:0 0 auto}
    .seg-legend .nm{flex:1;font-size:14px}
    .seg-legend .ct{font-weight:800;font-size:17px;font-variant-numeric:tabular-nums}
    .seg-legend .pc{color:var(--dim);font-size:12px;width:48px;text-align:right}
    /* sync progress ring */
    /* ring on the left, its numbers stacked to the right — nothing gets clipped */
    .ring-wrap{display:flex;flex-direction:row;align-items:center;justify-content:center;flex:1;gap:14px;min-height:0;overflow:hidden}
    .ring-side{display:flex;flex-direction:column;gap:5px;min-width:0;justify-content:center}
    .ringg{position:relative;width:min(15vh,130px);max-height:100%;aspect-ratio:1;flex:0 0 auto}
    .ring .throughput{margin-top:8px}
    .ring .throughput .n{font-size:20px}
    .ring #r-eta{line-height:1.35}
    /* remaining / running / queued as chips instead of one long grey line */
    .ring .throughput{justify-content:flex-start;margin-top:0}
    .ring .rchips{display:flex;flex-wrap:wrap;gap:4px;justify-content:flex-start;margin-top:2px}
    .ring .rchips span{background:var(--plane);border:1px solid var(--line);border-radius:999px;padding:2px 9px;font-size:11px;color:var(--muted);white-space:nowrap}
    .ring .rchips b{color:var(--ink);font-variant-numeric:tabular-nums}
    .ringg svg{transform:rotate(-90deg);width:100%;height:100%}
    .ringg .center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
    /* keep the % text comfortably inside the ring: size it from the ring itself */
    .ringg{container-type:inline-size}
    .ringg .center{padding:0 22%}
    .ringg .center .big{font-size:18cqw;font-weight:800;font-variant-numeric:tabular-nums;line-height:1;letter-spacing:-.5px;white-space:nowrap}
    .ringg .center .dim{font-size:7cqw!important;margin-top:3px;letter-spacing:.5px;text-transform:uppercase}
    .throughput{display:flex;align-items:baseline;gap:8px;justify-content:center;margin-top:2px}
    .throughput .n{font-size:24px;font-weight:800;color:var(--good);font-variant-numeric:tabular-nums}
    /* subjects (tall) */
    .subj .list,.grade .list{overflow-y:auto;display:flex;flex-direction:column;gap:5px;flex:1;min-height:0}
    .subj .list::-webkit-scrollbar,.grade .list::-webkit-scrollbar,.part::-webkit-scrollbar{width:6px}
    .subj .list::-webkit-scrollbar-thumb,.grade .list::-webkit-scrollbar-thumb,.part::-webkit-scrollbar-thumb{background:#ffffff22;border-radius:3px}
    .subrow{display:grid;grid-template-columns:130px 1fr 48px;align-items:center;gap:10px}
    .subrow .nm{font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .track{height:11px;background:var(--plane);border-radius:6px;overflow:hidden}
    .track > span{display:block;height:100%;background:linear-gradient(90deg,#16a34a,#22c55e);border-radius:6px;transition:width .6s ease}
    .subrow .pc{text-align:right;font-weight:800;font-variant-numeric:tabular-nums;font-size:13px}
    /* health strip */
    .health{flex:0 0 auto;display:grid;grid-template-columns:repeat(5,1fr);gap:14px}
    .hcard{background:linear-gradient(160deg,#1a2338,#131a2b);border:1px solid var(--line);border-radius:16px;padding:14px 18px;
      box-shadow:0 12px 30px -22px rgba(0,0,0,.9)}
    .hcard .l{font-size:12px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.5px}
    .hcard .v{font-size:26px;font-weight:800;margin-top:5px;font-variant-numeric:tabular-nums}
    .hcard .hsub{font-size:11px;color:var(--dim);margin-top:3px}

    /* ---------- RESPONSIVE ---------- */
    /* Large desktops / laptops: keep the 12-col wall but let rows breathe */
    @media (max-width:1600px){
      .health{grid-template-columns:repeat(5,1fr);gap:10px}
      .hcard{padding:12px 14px} .hcard .v{font-size:22px}
      .board{gap:10px} .tile{padding:14px 16px;border-radius:16px}
      .subrow{grid-template-columns:110px 1fr 44px}
    }
    /* Below 1280px the fixed-height wall stops working: switch to a scrolling page */
    @media (max-width:1280px){
      body{overflow:auto;height:auto;min-height:100vh;padding:12px;gap:12px}
      header{flex-wrap:wrap;row-gap:8px}
      header .spacer{display:none}
      .board{flex:0 0 auto;grid-template-columns:repeat(6,1fr);grid-template-rows:none;
        grid-template-areas:
          "hero hero hero ring ring ring"
          "status status status part part part"
          "today today today today today today"
          "subj subj subj grade grade grade"
          "velo velo velo feed feed feed";}
      .tile{min-height:220px}
      .hero,.ring{min-height:240px}
      .today,.feed{min-height:280px}
      .feed .flist{overflow-y:auto}
      .health{grid-template-columns:repeat(3,1fr)}
    }
    /* Tablets */
    @media (max-width:900px){
      .board{grid-template-columns:repeat(2,1fr);
        grid-template-areas:
          "hero hero"
          "ring status"
          "part today"
          "subj grade"
          "velo feed";}
      .health{grid-template-columns:repeat(2,1fr)}
      .seg-legend{grid-template-columns:1fr}
    }
    /* Phones */
    @media (max-width:640px){
      body{padding:10px;gap:10px}
      header{gap:8px}
      header .brand{font-size:17px;flex:1 1 100%}
      #clock{font-size:16px}
      .pill{font-size:11px;padding:5px 10px}
      .board{grid-template-columns:1fr;
        grid-template-areas:"hero" "ring" "status" "part" "today" "subj" "grade" "velo" "feed";}
      .tile{min-height:0;padding:14px}
      .hero,.ring,.today,.feed{min-height:0}
      .today .tlist,.feed .flist,.subj .list,.grade .list{max-height:300px;overflow-y:auto}
      .hero .val{font-size:40px} .kpi-val,.tot .val,.prog-t .val,.synced .val{font-size:32px}
      .today .snm{min-width:0;max-width:100%;flex:1 1 100%}
      .subrow{grid-template-columns:90px 1fr 40px}
      .part .prow{flex-wrap:wrap}
      .health{grid-template-columns:1fr 1fr;gap:10px}
      .ringg{width:150px}
      .velo .bars{min-height:120px}
    }
  </style>
</head>
<body data-palette="#0ca30c,#fab219,#3987e5,#6b6a63">
  <header>
    <div class="brand"><span class="dot"></span>FastTest — Live Overview
      <small style="display:block;font-size:12px;font-weight:500;color:var(--dim);letter-spacing:0;margin-top:2px">Real-time operations wall · exam delivery &amp; FastTest sync at a glance</small>
    </div>
    <span class="pill" id="healthPill">FastTest: —</span>
    <span class="pill" id="wsPill">Workspace: —</span>
    <div class="spacer"></div>
    <span class="pill" id="modePill">Mode: —</span>
    <span class="pill" id="syncPill">Last sync: —</span>
    <span id="clock">--:--:--</span>
  </header>

  <section class="board">
    <!-- HERO: Completed -->
    <div class="tile hero a-completed">
      <div class="label">Completed Exams</div>
      <div class="val" id="t-completed">—</div>
      <div class="prog"><span id="hero-prog" style="width:0%"></span></div>
      <div class="sub" id="t-completionrate">—</div>
      <svg class="spark" id="heroSpark" viewBox="0 0 400 52" preserveAspectRatio="none"></svg>
    </div>

    <!-- Sync progress ring -->
    <div class="tile ring">
      <div class="cap">Sync Progress</div>
      <div class="ring-wrap">
        <div class="ringg">
          <svg viewBox="0 0 100 100">
            <circle cx="50" cy="50" r="43" fill="none" stroke="#26324a" stroke-width="7"></circle>
            <circle id="ringFg" cx="50" cy="50" r="43" fill="none" stroke="var(--good)" stroke-width="7" stroke-linecap="round" stroke-dasharray="270.2" stroke-dashoffset="270.2"></circle>
          </svg>
          <div class="center"><div class="big" id="r-pc">—</div><div class="dim" style="font-size:12px">synced</div></div>
        </div>
        <div class="ring-side">
          <div class="throughput"><span class="n" id="r-tput">—</span><span class="muted" style="font-size:12px">sync/min · live</span></div>
          <div class="rchips" id="r-remaining"></div>
          <div id="r-eta" style="font-size:12px;font-weight:700;color:var(--muted)">—</div>
        </div>
      </div>
    </div>

    <!-- Registration status -->
    <div class="tile status">
      <div class="cap">Registration Status</div>
      <div class="segbar" id="segbar"></div>
      <div class="seg-legend" id="legend"></div>
    </div>

    <!-- Subjects -->
    <div class="tile subj">
      <div class="cap">Completion by Subject</div>
      <div class="list" id="subjects"></div>
    </div>

    <!-- Grades -->
    <div class="tile grade">
      <div class="cap">Completion by Grade</div>
      <div class="list" id="grades"></div>
    </div>

    <!-- Today's activity: schools + grades with status changes today -->
    <div class="tile today">
      <div class="cap">📅 Today's Activity — schools with student status changes today</div>
      <div class="tlist" id="todayList"></div>
    </div>

    <!-- Live sync feed -->
    <div class="tile feed">
      <div class="cap">🔴 Live Sync Feed — latest checked codes</div>
      <div class="flist" id="syncFeed"></div>
    </div>

    <!-- small KPIs -->
    <!-- Participation coverage (targeted vs participating + achieved gauges) -->
    <div class="tile part">
      <div class="cap">Participation Coverage</div>
      <div class="prow">
        <span class="pico">🏫</span>
        <div class="pstat"><div class="pn" id="pSchP">—</div><div class="pt">Participating schools</div></div>
        <div class="pstat dim2"><div class="pn" id="pSchT">—</div><div class="pt">Targeted</div></div>
        <div class="pg"><svg viewBox="0 0 36 36"><circle class="g-bg" cx="18" cy="18" r="15.9155"></circle><circle class="g-fg" id="gSch" cx="18" cy="18" r="15.9155"></circle></svg><span class="gpc" id="pSchR">—</span></div>
      </div>
      <div class="prow">
        <span class="pico">👥</span>
        <div class="pstat"><div class="pn" id="pStuP">—</div><div class="pt">Participating students</div></div>
        <div class="pstat dim2"><div class="pn" id="pStuT">—</div><div class="pt">Targeted</div></div>
        <div class="pg"><svg viewBox="0 0 36 36"><circle class="g-bg" cx="18" cy="18" r="15.9155"></circle><circle class="g-fg" id="gStu" cx="18" cy="18" r="15.9155"></circle></svg><span class="gpc" id="pStuR">—</span></div>
      </div>
      <div class="sub" id="t-subjects" style="margin-top:auto">—</div>
    </div>
    <!-- Daily velocity (replaces redundant Synced tile) -->
    <div class="tile velo a-completed">
      <div class="cap">⏰ Activity by Hour<span class="peak" id="veloPeak"></span></div>
      <div class="bars" id="veloBars"></div>
    </div>
  </section>

  <section class="health">
    <div class="hcard"><div class="l">API Success</div><div class="v" id="h-api">—</div></div>
    <div class="hcard"><div class="l">Avg Response</div><div class="v" id="h-resp">—</div></div>
    <div class="hcard"><div class="l">⚠ Rapid Completions (&lt;2m)</div><div class="v" id="h-rapid">—</div><div class="hsub" id="h-rapid-sub">needs review</div></div>
    <div class="hcard"><div class="l">Avg Time Used</div><div class="v" id="h-time">—</div></div>
    <div class="hcard"><div class="l">🕒 Stale Data / Errors</div><div class="v" id="h-stale">—</div><div class="hsub" id="h-stale-sub">not synced recently</div></div>
  </section>

  <script>
    var STATUS = [
      {key:'NOT_SYNCED',  name:'Not Synced',  color:'#6b6a63'},
      {key:'NOT_STARTED', name:'Not Started', color:'#3987e5'},
      {key:'IN_PROGRESS', name:'In Progress', color:'#fab219'},
      {key:'COMPLETED',   name:'Completed',   color:'#0ca30c'}
    ];
    var fmt = function(n){ return (n==null||isNaN(n)) ? '—' : Number(n).toLocaleString('en-US'); };
    var pct = function(n,d){ return d>0 ? Math.round(n/d*1000)/10 : 0; };
    var ago = function(iso){ if(!iso) return '—'; var s=Math.max(0,(Date.now()-new Date(iso).getTime())/1000);
      if(s<60) return Math.round(s)+'s ago'; if(s<3600) return Math.round(s/60)+'m ago'; return Math.round(s/3600)+'h ago'; };
    var mmss = function(sec){ if(sec==null) return '—'; var m=Math.floor(sec/60), s=Math.round(sec%60); return m+'m '+(s<10?'0':'')+s+'s'; };
    var fmtDur = function(min){ if(min<1) return '<1m'; if(min<60) return Math.round(min)+'m'; var h=Math.floor(min/60), m=Math.round(min%60); return h+'h '+(m<10?'0':'')+m+'m'; };
    var syncHist = []; // rolling samples of `synced` to measure the real sync rate for ETA

    function tick(){ var d=new Date(); document.getElementById('clock').textContent = d.toLocaleTimeString('en-GB'); }
    setInterval(tick,1000); tick();

    async function j(u){ var r=await fetch(u,{headers:{Accept:'application/json'}}); if(!r.ok) throw new Error(u+' '+r.status); return r.json(); }

    var SVGNS='http://www.w3.org/2000/svg';
    function heroSpark(pts){
      var svg=document.getElementById('heroSpark'); if(!svg) return; svg.innerHTML='';
      if(pts.length<2) return;
      var W=400,H=52,max=Math.max.apply(null,pts)||1;
      var x=function(i){return i/(pts.length-1)*W;}, y=function(v){return H-3-(v/max)*(H-8);};
      var dl='',da='M0,'+H;
      pts.forEach(function(v,i){dl+=(i?' L':'M')+x(i).toFixed(1)+','+y(v).toFixed(1);da+=' L'+x(i).toFixed(1)+','+y(v).toFixed(1);});
      da+=' L'+W+','+H+' Z';
      var a=document.createElementNS(SVGNS,'path');a.setAttribute('d',da);a.setAttribute('fill','#22c55e');a.setAttribute('opacity','.18');svg.appendChild(a);
      var l=document.createElementNS(SVGNS,'path');l.setAttribute('d',dl);l.setAttribute('fill','none');l.setAttribute('stroke','#22c55e');l.setAttribute('stroke-width','2');l.setAttribute('vector-effect','non-scaling-stroke');svg.appendChild(l);
    }
    function gauge(circleId, pctId, pct){
      var c=document.getElementById(circleId), t=document.getElementById(pctId); if(!c) return;
      var col = pct>=90?'#22c55e':pct>=70?'#f59e0b':'#ef4444';
      c.style.stroke=col; c.style.strokeDashoffset=(100-Math.max(0,Math.min(100,pct))).toFixed(1);
      if(t){ t.textContent=pct+'%'; t.style.color=col; }
    }
    function veloBars(items){
      var box=document.getElementById('veloBars'); if(!box) return; box.innerHTML='';
      var max=Math.max.apply(null,items.map(function(i){return i.v;}).concat([1]));
      var avail=Math.max(24,(box.clientHeight||150)-18); // room for the axis label
      // labels collide when bars are narrow — show every Nth only
      var step=Math.ceil(items.length/(Math.max(1,Math.floor((box.clientWidth||400)/30))));
      var peakIdx=items.reduce(function(p,i,n){return i.v>items[p].v?n:p;},0);
      items.forEach(function(i,idx){
        var b=document.createElement('div');
        b.className='b'+(i.v===0?' zero':'')+(idx===peakIdx&&i.v>0?' top':'');
        var hpx=Math.max(2,Math.round(i.v/max*avail));
        b.innerHTML='<div class="bar" style="height:'+hpx+'px"></div>'+
          '<div class="bl">'+((idx%step===0)?i.l:'')+'</div>';
        b.title=i.l+': '+fmt(i.v);
        box.appendChild(b);
      });
      var pk=document.getElementById('veloPeak');
      if(pk) pk.innerHTML = items[peakIdx].v>0
        ? 'peak <b style="color:#86efac">'+items[peakIdx].l+':00</b> · '+fmt(items[peakIdx].v)
        : '';
    }

    async function refresh(){
      try{
        var brandDot = document.querySelector('.brand .dot');
        var ov, subj, q, health, exam, feed, today, part, gradesData;
        try { [ov, subj, q, health, exam, feed, today, part, gradesData] = await Promise.all([
          j('/api/dashboard/overview'), j('/api/dashboard/subjects'),
          j('/api/queue/stats').catch(function(){return null;}), j('/api/dashboard/api-health').catch(function(){return null;}),
          j('/api/dashboard/exam-analytics').catch(function(){return null;}),
          j('/api/dashboard/sync-feed').catch(function(){return null;}),
          j('/api/dashboard/todays-activity').catch(function(){return null;}),
          j('/api/dashboard/participation').catch(function(){return null;}),
          j('/api/dashboard/completion-by-grade').catch(function(){return {grades:[]};})
        ]); } catch(e){ brandDot.style.background='#d03b3b'; brandDot.style.boxShadow='0 0 10px #d03b3b'; return; }
        brandDot.style.background='#0ca30c'; brandDot.style.boxShadow='0 0 10px #0ca30c';

        var total = ov.totalRegistered||0;
        var synced = total - (ov.NOT_SYNCED||0);
        // tiles
        document.getElementById('t-subjects').textContent = fmt(total)+' registrations · '+(subj.subjects?subj.subjects.length:0)+' subjects';
        // participation coverage + achieved gauges
        if (part) {
          document.getElementById('pSchP').textContent = fmt(part.schools.participating);
          document.getElementById('pSchT').textContent = 'of '+fmt(part.schools.targeted);
          document.getElementById('pStuP').textContent = fmt(part.students.participating);
          document.getElementById('pStuT').textContent = 'of '+fmt(part.students.targeted);
          gauge('gSch','pSchR',part.schools.rate);
          gauge('gStu','pStuR',part.students.rate);
        }
        document.getElementById('t-completed').textContent = fmt(ov.COMPLETED);
        document.getElementById('t-completionrate').textContent = (ov.completionRate!=null?ov.completionRate+'% completion rate':'');
        document.getElementById('hero-prog').style.width = (ov.completionRate!=null?ov.completionRate:0)+'%';

        // hero completion trend sparkline + daily velocity bars (from exam analytics)
        var daily = (exam && exam.daily) ? exam.daily : [];
        heroSpark(daily.map(function(d){return d.count||0;}));
        // hour-of-day activity — fill missing hours so the axis always reads 00 → 23
        var hmap={}; ((exam&&exam.byHour)||[]).forEach(function(h){hmap[h.hour]=h.count;});
        // trim the dead night hours: chart only the active window (padded by one hour)
        var act=Object.keys(hmap).map(Number).filter(function(h){return hmap[h]>0;});
        var lo=act.length?Math.max(0,Math.min.apply(null,act)-1):0;
        var hi=act.length?Math.min(23,Math.max.apply(null,act)+1):23;
        var hours=[]; for(var hh=lo;hh<=hi;hh++) hours.push({l:(hh<10?'0':'')+hh, v:hmap[hh]||0});
        veloBars(hours);

        // today's activity: schools + grades with status changes today
        var tl = document.getElementById('todayList');
        if (today && today.schools) {
          if (!today.schools.length) {
            tl.innerHTML = '<div class="empty">No student status changes yet today.</div>';
          } else {
            tl.innerHTML = today.schools.map(function(s){
              var chips = s.grades.map(function(g){ var gr=/grade/i.test(String(g.grade))?g.grade:'Grade '+g.grade; return '<span class="gchip">'+gr+' <b>'+fmt(g.count)+'</b></span>'; }).join('');
              return '<div class="trow"><span class="snm" title="'+s.schoolName+'">'+s.schoolName+'</span><span class="stot">'+fmt(s.total)+'</span><span class="gchips">'+chips+'</span></div>';
            }).join('');
          }
        }

        // live sync feed (latest checked codes + status)
        var fl = document.getElementById('syncFeed');
        if (feed && feed.items) {
          fl.innerHTML = feed.items.map(function(it){
            var st = String(it.status||'UNKNOWN');
            return '<div class="frow"><div><div class="code">'+(it.code||'—')+'</div><div class="sub">'+(it.subject||'')+'</div></div>'+
              '<span class="st st-'+st+'">'+st.replace(/_/g,' ')+'</span>'+
              '<span class="tm">'+ago(it.at)+'</span></div>';
          }).join('');
        }

        // status segmented bar + legend
        var seg = document.getElementById('segbar'); var leg = document.getElementById('legend');
        seg.innerHTML=''; leg.innerHTML='';
        STATUS.forEach(function(s){
          var v = ov[s.key]||0; var w = total>0 ? (v/total*100) : 0;
          var d = document.createElement('div'); d.style.width=w+'%'; d.style.background=s.color; d.title=s.name+': '+fmt(v); seg.appendChild(d);
          var row=document.createElement('div'); row.className='row';
          row.innerHTML='<span class="sw" style="background:'+s.color+'"></span><span class="nm">'+s.name+'</span><span class="ct">'+fmt(v)+'</span><span class="pc">'+pct(v,total)+'%</span>';
          leg.appendChild(row);
        });

        // sync ring
        var p = pct(synced,total);
        document.getElementById('r-pc').textContent = p+'%';
        var C=270.2, rf=document.getElementById('ringFg');
        rf.style.strokeDashoffset = (C-(C*p/100)).toFixed(1);
        rf.style.stroke = p>=95?'#22c55e':p>=70?'#f59e0b':'#ef4444';
        var tput = q ? (q.jobsLastMin||0) : 0;
        document.getElementById('r-tput').textContent = fmt(tput);
        document.getElementById('r-remaining').innerHTML =
          '<span><b>'+fmt(ov.NOT_SYNCED||0)+'</b> remaining</span>'+
          (q ? '<span><b>'+fmt(q.running||0)+'</b> running</span><span><b>'+fmt(q.queued||0)+'</b> queued</span>' : '');

        // Sync ETA — measured from the real rate the synced count is rising
        var nowMs=Date.now(); syncHist.push({t:nowMs,s:synced});
        syncHist=syncHist.filter(function(h){return nowMs-h.t<=300000;}); // 5-min window
        var remaining=ov.NOT_SYNCED||0, etaEl=document.getElementById('r-eta');
        if(remaining<=0){ etaEl.textContent='✓ Fully synced'; etaEl.style.color='#4ade80'; }
        else {
          var rate=0; // synced/min — prefer the measured rate, fall back to live throughput
          if(syncHist.length>=2){ var o=syncHist[0], dt=(nowMs-o.t)/60000, ds=synced-o.s; if(dt>=0.5 && ds>0) rate=ds/dt; }
          if(!rate && q && q.jobsLastMin>0) rate=q.jobsLastMin;
          if(rate>0){ etaEl.textContent='⏱ ETA ~'+fmtDur(remaining/rate)+' to 100% · '+fmt(Math.round(rate))+'/min'; etaEl.style.color='#38bdf8'; }
          else { etaEl.textContent='⏱ ETA — · sync idle'; etaEl.style.color='var(--dim)'; }
        }

        // subjects (sorted by total desc, top 8)
        var sd = document.getElementById('subjects'); sd.innerHTML='';
        (subj.subjects||[]).slice().sort(function(a,b){return b.total-a.total;}).forEach(function(s){
          var cr = s.completionRate!=null ? s.completionRate : pct(s.COMPLETED, s.total);
          var row=document.createElement('div'); row.className='subrow';
          row.innerHTML='<span class="nm" title="'+s.examSubject+'">'+s.examSubject+'</span>'+
            '<span class="track"><span style="width:'+cr+'%"></span></span>'+
            '<span class="pc">'+cr+'%</span>';
          sd.appendChild(row);
        });

        // completion by grade
        var gd = document.getElementById('grades'); gd.innerHTML='';
        ((gradesData&&gradesData.grades)||[]).forEach(function(g){
          var gr = /grade/i.test(String(g.grade))?g.grade:'Grade '+g.grade;
          var cr = g.completionRate!=null?g.completionRate:0;
          var row=document.createElement('div'); row.className='subrow';
          row.innerHTML='<span class="nm" title="'+gr+'">'+gr+'</span>'+
            '<span class="track"><span style="width:'+cr+'%"></span></span>'+
            '<span class="pc">'+cr+'%</span>';
          gd.appendChild(row);
        });

        // header pills
        var mp=document.getElementById('modePill');
        if(q){ /* mode comes from control-state; fetch lightly */ }
        document.getElementById('syncPill').textContent='Last sync: '+ago(ov.lastSuccessfulSyncAt);
        if(health && health.workspaces && health.workspaces[0]){
          var w0=health.workspaces[0];
          var wp=document.getElementById('wsPill'); wp.textContent='Workspace: '+w0.workspaceName+' · '+w0.connectionStatus;
          wp.className='pill '+(w0.connectionStatus==='SUCCESS'?'on':'off');
        }

        // health strip
        document.getElementById('h-api').textContent = (ov.apiSuccessRate!=null?ov.apiSuccessRate+'%':'—');
        document.getElementById('h-resp').textContent = (ov.avgResponseTimeMs!=null?ov.avgResponseTimeMs+' ms':'—');
        // Rapid completions (<2 min) — integrity flag
        var rapid=(exam&&exam.time)?exam.time.rapidCount:0, rtot=(exam&&exam.time)?exam.time.total:0;
        var hr=document.getElementById('h-rapid'); hr.textContent=fmt(rapid); hr.style.color=rapid>0?'#f87171':'#4ade80';
        document.getElementById('h-rapid-sub').textContent=(rtot>0?Math.round(rapid/rtot*1000)/10:0)+'% of completed';
        document.getElementById('h-time').textContent = mmss(ov.avgTimeUsedSeconds);
        var stale=(ov.staleCount||0), errs=(ov.syncErrors||0);
        var hs=document.getElementById('h-stale'); hs.textContent = fmt(stale)+' / '+fmt(errs);
        hs.style.color = errs>0 ? '#ef4444' : (stale>0 ? '#fab219' : '#4ade80');
        document.getElementById('h-stale-sub').textContent = (stale>0?Math.round(stale/(ov.totalRegistered||1)*1000)/10+'% of data':'all fresh');
      }catch(e){ /* keep last good values */ }
    }

    // FastTest health verdict pill (reads local logs — no FastTest load)
    async function refreshHealth(){
      try{ var h=await j('/api/fasttest/health');
        var hp=document.getElementById('healthPill');
        var icon = h.verdict==='HEALTHY'?'🟢':(h.verdict==='DEGRADED'?'🟡':'🔴');
        var col  = h.verdict==='HEALTHY'?'#0ca30c':(h.verdict==='DEGRADED'?'#fab219':'#d03b3b');
        hp.textContent = icon+' FastTest: '+h.verdict+'  ·  '+h.calls.successRate+'% · p95 '+h.latency.p95+'ms · '+(h.workspace?h.workspace.circuit:'—');
        hp.style.color = col; hp.style.borderColor = col+'66';
      }catch(e){}
    }

    // fetch control-state separately for the mode pill
    async function refreshMode(){
      try{ var s=await j('/api/queue/control-state');
        var mp=document.getElementById('modePill');
        if(s.globalPaused){ mp.textContent='Sync: PAUSED'; mp.className='pill off'; }
        else if(s.fastMode){ mp.textContent='Mode: ⚡ FAST'; mp.className='pill fast'; }
        else { mp.textContent='Mode: Normal'; mp.className='pill on'; }
      }catch(e){}
    }

    refresh(); refreshMode(); refreshHealth();
    setInterval(refresh, 4000);
    setInterval(refreshMode, 6000);
    setInterval(refreshHealth, 6000);
  </script>
</body>
</html>
