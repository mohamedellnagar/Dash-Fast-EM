<%- include('partials/head') %>
<%- include('partials/nav') %>

<% if (flash) { %><div class="alert ok"><%= flash %></div><% } %>

<div class="panel">
  <h2>FastTest Workspaces</h2>
  <table>
    <thead><tr><th>Workspace</th><th>Subject</th><th>Base URL</th><th>API Key</th><th>Active</th><th>Sync</th><th>Rate limit (per workspace)</th><th>Last Auth</th><th></th></tr></thead>
    <tbody>
      <% workspaces.forEach(function(w){ %>
        <tr>
          <td><%= w.workspaceName %></td>
          <td><%= w.subjectCode %></td>
          <td class="mono" style="max-width:200px;overflow:hidden;text-overflow:ellipsis"><%= w.baseUrl %></td>
          <td class="mono"><%= w.hasApiKey ? w.restApiKeyMasked : '(none)' %></td>
          <td><%= w.isActive ? 'Yes' : 'No' %></td>
          <td><%= w.syncEnabled ? 'On' : 'Off' %></td>
          <td>
            <label style="font-size:11px;display:flex;align-items:center;gap:5px;margin-bottom:5px" title="Let the system raise/lower the rate automatically based on FastTest health (AIMD)">
              <input type="checkbox" class="autotune-cb" data-id="<%= w.id %>" <%= w.rateLimit.autoTune ? 'checked' : '' %>>
              <span style="color:<%= w.rateLimit.autoTune ? '#22c55e' : 'var(--muted)' %>;font-weight:700">⚙️ Auto</span>
              <% if (w.rateLimit.autoTune) { %><span class="muted">· now <b><%= w.rateLimit.maxRpm %></b> rpm</span><% } %>
            </label>
            <form class="rate-form" data-id="<%= w.id %>" style="display:<%= w.rateLimit.autoTune ? 'none' : 'flex' %>;gap:6px;align-items:center;flex-wrap:wrap;margin:0">
              <label style="font-size:11px;color:var(--muted)" title="Requests per minute (main throughput cap)">rpm <input name="maxRpm" type="number" min="1" max="6000" value="<%= w.rateLimit.maxRpm %>" style="width:64px" required></label>
              <label style="font-size:11px;color:var(--muted)" title="Requests per second (burst cap)">rps <input name="maxRps" type="number" min="0.1" max="100" step="0.1" value="<%= w.rateLimit.maxRps %>" style="width:52px" required></label>
              <label style="font-size:11px;color:var(--muted)" title="Max concurrent in-flight requests">conc <input name="maxConcurrent" type="number" min="1" max="64" value="<%= w.rateLimit.maxConcurrent %>" style="width:48px" required></label>
              <button class="btn sm" type="submit">Save</button>
              <% if (w.rateLimit.isDefault) { %><span class="muted" style="font-size:10px">(default)</span><% } %>
            </form>
          </td>
          <td>
            <% if (w.lastAuthenticationStatus) { %>
              <span class="status <%= w.lastAuthenticationStatus==='SUCCESS'?'OK':'ERROR' %>"><%= w.lastAuthenticationStatus %></span>
              <span class="muted"><%= w.lastAuthenticationAt ? new Date(w.lastAuthenticationAt).toLocaleString() : '' %></span>
            <% } else { %><span class="muted">never</span><% } %>
          </td>
          <td><button class="btn secondary sm test-btn" data-id="<%= w.id %>">Test</button></td>
        </tr>
      <% }); %>
      <% if (workspaces.length===0){ %><tr><td colspan="9" class="muted">No workspaces configured.</td></tr><% } %>
    </tbody>
  </table>
</div>

<div class="grid2">
  <div class="panel">
    <h2>Add Workspace</h2>
    <form action="/admin/integration/workspaces" method="post">
      <div class="filters" style="flex-direction:column;align-items:stretch">
        <label>Workspace Name<input name="workspaceName" required /></label>
        <label>Subject Code (canonical, e.g. ARABIC)<input name="subjectCode" required /></label>
        <label>Base URL<input name="baseUrl" type="url" value="https://uae.fasttestweb.com/FastTest/api" required /></label>
        <label>REST API Key<input name="restApiKey" type="password" placeholder="stored encrypted" /></label>
        <label>Username (optional)<input name="username" /></label>
        <label>Password (optional)<input name="password" type="password" /></label>
        <label>Token TTL (seconds)<input name="tokenTTL" type="number" value="3600" /></label>
        <button class="btn" type="submit">Create Workspace</button>
      </div>
    </form>
  </div>

  <div class="panel">
    <h2>Subject Alias Mappings</h2>
    <form action="/admin/integration/mappings" method="post" class="filters">
      <label>Alias (as in source ExamSubject)<input name="subjectAlias" placeholder="Arabic Reading" required /></label>
      <label>Workspace
        <select name="workspaceId" required>
          <% workspaces.forEach(function(w){ %><option value="<%= w.id %>"><%= w.workspaceName %></option><% }); %>
        </select>
      </label>
      <button class="btn" type="submit">Save Mapping</button>
    </form>
    <table style="margin-top:12px">
      <thead><tr><th>Alias</th><th>→ Workspace</th></tr></thead>
      <tbody>
        <% mappings.forEach(function(m){ %><tr><td><%= m.subjectAlias %></td><td><%= m.workspace.workspaceName %></td></tr><% }); %>
        <% if (mappings.length===0){ %><tr><td colspan="2" class="muted">No aliases mapped.</td></tr><% } %>
      </tbody>
    </table>
  </div>
</div>

<script>
  document.querySelectorAll('.test-btn').forEach(function(b){
    b.addEventListener('click', async function(){
      b.disabled = true; b.textContent = 'Testing…';
      try {
        const res = await fetch('/admin/integration/workspaces/' + b.dataset.id + '/test', { method:'POST', headers:{'Accept':'application/json'} });
        const j = await res.json();
        b.textContent = j.ok ? 'OK ✓' : ('Fail: ' + (j.error||''));
      } catch(e){ b.textContent = 'Error'; }
      b.disabled = false;
    });
  });

  // Per-workspace rate-limit save.
  document.querySelectorAll('.rate-form').forEach(function(f){
    f.addEventListener('submit', async function(e){
      e.preventDefault();
      var btn = f.querySelector('button[type=submit]');
      btn.disabled = true; var old = btn.textContent; btn.textContent = 'Saving…';
      try {
        var res = await fetch('/api/queue/workspaces/' + f.dataset.id + '/rate-limit', {
          method:'POST', headers:{'Content-Type':'application/json','Accept':'application/json'},
          body: JSON.stringify({ maxRpm: f.maxRpm.value, maxRps: f.maxRps.value, maxConcurrent: f.maxConcurrent.value })
        });
        var j = await res.json();
        btn.textContent = j.ok ? 'Saved ✓' : ('Fail: ' + (j.error||''));
      } catch(err){ btn.textContent = 'Error'; }
      setTimeout(function(){ btn.textContent = old; btn.disabled = false; }, 1500);
    });
  });

  // Per-workspace auto-tune toggle.
  document.querySelectorAll('.autotune-cb').forEach(function(cb){
    cb.addEventListener('change', async function(){
      cb.disabled = true;
      try {
        await fetch('/api/queue/workspaces/' + cb.dataset.id + '/autotune', {
          method:'POST', headers:{'Content-Type':'application/json','Accept':'application/json'},
          body: JSON.stringify({ enabled: cb.checked })
        });
        location.reload();
      } catch(e){ cb.disabled = false; cb.checked = !cb.checked; }
    });
  });
</script>

<%- include('partials/foot') %>
