<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Operations Center — Exam Delivery Overview</title>
  <style>
    :root{
      --plane:#0a0f1a; --surface:#141c2e; --line:#26324a; --ink:#fff; --muted:#c3c2b7; --dim:#8a897f;
      --ok:#22c55e; --warn:#f59e0b; --bad:#ef4444; --info:#3b82f6; --accent:#818cf8;
      --c-completed:#22c55e; --c-inprogress:#f59e0b; --c-notstarted:#3b82f6; --c-notsynced:#6b7280;
    }
    *{box-sizing:border-box;margin:0;padding:0}
    html,body{height:100%}
    body{background:radial-gradient(1200px 700px at 15% -10%,#16213a 0%,var(--plane) 55%);color:var(--ink);
      font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;overflow:hidden;
      display:flex;flex-direction:column;height:100vh;padding:16px;gap:14px}
    .muted{color:var(--muted)} .dim{color:var(--dim)}
    header{display:flex;align-items:center;gap:14px;flex:0 0 auto}
    header .brand{font-size:21px;font-weight:800}
    header .brand small{display:block;font-size:12px;font-weight:500;color:var(--dim);margin-top:2px}
    header .spacer{flex:1}
    .pill{padding:6px 13px;border-radius:999px;font-size:13px;font-weight:700;border:1px solid var(--line);background:var(--surface);white-space:nowrap}
    #clock{font-variant-numeric:tabular-nums;font-size:20px;font-weight:700}
    .kpis{flex:0 0 auto;display:grid;grid-template-columns:repeat(6,1fr);gap:14px}
    .kpi{background:linear-gradient(160deg,#1a2338,#131a2b);border:1px solid var(--line);border-radius:16px;padding:14px 18px;position:relative;overflow:hidden}
    .kpi::after{content:"";position:absolute;left:0;top:0;width:100%;height:3px;background:var(--accent);opacity:.6}
    .kpi .l{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--muted)}
    .kpi .v{font-size:clamp(26px,3vw,40px);font-weight:800;font-variant-numeric:tabular-nums;line-height:1;margin-top:6px}
    .kpi .s{font-size:12px;color:var(--dim);margin-top:4px}
    .kpi.now::after{background:var(--warn)} .kpi.now .v{color:var(--warn)}
    .kpi.done::after{background:var(--ok)} .kpi.done .v{color:var(--ok)}
    .kpi.rapid::after{background:var(--bad)} .kpi.rapid .v{color:var(--bad)} .kpi.rapid{grid-column:span 2}
    /* participation group cards (targeted vs participating + achieved gauge) */
    .pgroup{grid-column:span 2;background:linear-gradient(160deg,#1a2338,#131a2b);border:1px solid var(--line);border-radius:16px;padding:12px 18px;display:flex;flex-direction:column}
    .pgl{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);margin-bottom:8px}
    .pgb{display:flex;align-items:center;gap:16px;flex:1}
    .pgn{font-size:clamp(20px,2.2vw,30px);font-weight:800;font-variant-numeric:tabular-nums;line-height:1}
    .pgt{font-size:11px;color:var(--dim);margin-top:3px}
    .pgsep{width:1px;align-self:stretch;background:var(--line)}
    .gauge{position:relative;width:58px;height:58px;flex:0 0 auto;margin-left:auto}
    .gauge svg{width:100%;height:100%;transform:rotate(-90deg)}
    .gauge .g-bg{fill:none;stroke:#26324a;stroke-width:3.4}
    .gauge .g-fg{fill:none;stroke-width:3.4;stroke-linecap:round;stroke-dasharray:100;stroke-dashoffset:100;transition:stroke-dashoffset .6s ease}
    .gauge .gpc{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800}
    .gauge .gcap{position:absolute;left:0;right:0;bottom:-15px;text-align:center;font-size:9px;color:var(--dim);text-transform:uppercase;letter-spacing:.4px}
    .board{flex:1 1 auto;display:grid;gap:14px;min-height:0;grid-template-columns:repeat(12,1fr);grid-template-rows:1fr 1fr;
      grid-template-areas:
        "schools schools schools schools funnel funnel funnel funnel subj subj subj subj"
        "schools schools schools schools grade grade grade grade time time time time";}
    .tile{background:linear-gradient(160deg,#1a2338,#131a2b);border:1px solid var(--line);border-radius:18px;padding:16px 18px;display:flex;flex-direction:column;min-height:0;
      box-shadow:0 18px 40px -22px rgba(0,0,0,.9)}
    .tile .cap{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);margin-bottom:12px;flex:0 0 auto}
    .schools{grid-area:schools} .funnel{grid-area:funnel} .subj{grid-area:subj} .grade{grid-area:grade} .hour{grid-area:hour} .daily{grid-area:daily} .time{grid-area:time}
    /* time & integrity: rapid-completion flag + time-used distribution */
    .flag{display:flex;align-items:center;gap:10px;background:#ef444414;border:1px solid #ef444433;border-radius:10px;padding:9px 12px;margin-bottom:8px;flex:0 0 auto}
    .flag .big{font-size:24px;font-weight:800;color:#ef4444;font-variant-numeric:tabular-nums}
    .time .vbars{overflow:hidden}
    .hlist{overflow-y:auto;display:flex;flex-direction:column;gap:6px;flex:1;min-height:0}
    .hlist::-webkit-scrollbar{width:6px} .hlist::-webkit-scrollbar-thumb{background:#ffffff22;border-radius:3px}
    .hrow{display:grid;grid-template-columns:130px 1fr 46px;align-items:center;gap:10px}
    .hrow .nm{font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .hrow .track{height:11px;background:var(--plane);border-radius:6px;overflow:hidden}
    .hrow .track > span{display:block;height:100%;border-radius:6px;transition:width .6s ease}
    .hrow .pc{text-align:right;font-weight:800;font-size:13px;font-variant-numeric:tabular-nums}
    /* completion-threshold filter buttons on the schools tile */
    .fbtns{display:flex;gap:6px;flex:0 0 auto;margin-bottom:8px;flex-wrap:wrap}
    /* schools completion-rate slider */
    .schslider{display:flex;align-items:center;gap:12px;flex:0 0 auto;margin-bottom:10px}
    .schslider .ss-lbl{font-size:12px;color:var(--muted);white-space:nowrap}
    .schslider .ss-lbl b{font-variant-numeric:tabular-nums;font-size:14px;color:#22c55e}
    .schslider input[type=range]{flex:1;height:6px;-webkit-appearance:none;appearance:none;border-radius:6px;
      background:linear-gradient(90deg,#ef4444,#f59e0b,#22c55e);outline:none;cursor:pointer}
    .schslider input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;appearance:none;width:18px;height:18px;
      border-radius:50%;background:#fff;border:2px solid #0a0f1a;box-shadow:0 1px 4px rgba(0,0,0,.5);cursor:pointer}
    .schslider input[type=range]::-moz-range-thumb{width:18px;height:18px;border-radius:50%;background:#fff;
      border:2px solid #0a0f1a;box-shadow:0 1px 4px rgba(0,0,0,.5);cursor:pointer}
    .fbtns button{cursor:pointer;font:inherit;font-size:11px;font-weight:700;padding:4px 11px;border-radius:999px;
      border:1px solid var(--line);background:var(--surface);color:var(--muted);transition:.15s}
    .fbtns button:hover{color:var(--ink);border-color:#ffffff33}
    .fbtns button.on{background:#3b82f622;border-color:#3b82f688;color:#93c5fd}
    .cap .scount{float:right;font-weight:800;color:var(--dim);text-transform:none;letter-spacing:0}
    .funnel #funnel{display:flex;flex-direction:column;justify-content:center;gap:10px;min-height:0;flex:1}
    /* page-wide subject filter bar under the header */
    .subjbar{flex:0 0 auto;display:flex;align-items:center;gap:10px;background:linear-gradient(160deg,#1a2338,#131a2b);
      border:1px solid var(--line);border-radius:14px;padding:8px 14px}
    .subjbar-lbl{font-size:12px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;flex:0 0 auto}
    #pageFilters{display:flex;flex-wrap:wrap;gap:6px;flex:1}
    .funnel .fstage{margin-bottom:0}
    .funnel .fstage .fh b{font-size:17px}
    .funnel .fstage .fbar{height:13px}
    .hlist .empty{color:var(--dim);font-size:13px;padding:10px 2px}
    .fstage{margin-bottom:14px} .fstage:last-child{margin-bottom:0}
    .fstage .fh{display:flex;justify-content:space-between;align-items:baseline;font-size:13px;margin-bottom:5px}
    .fstage .fh b{font-size:20px;font-variant-numeric:tabular-nums}
    .fstage .fbar{height:16px;background:var(--plane);border-radius:8px;overflow:hidden}
    .fstage .fbar > span{display:block;height:100%;border-radius:8px;transition:width .6s ease}
    .vbars{display:flex;align-items:flex-end;gap:5px;flex:1;height:100%;min-height:0;margin-top:6px}
    .vbars .b{flex:1;min-width:0;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;gap:4px;height:100%}
    .vbars .b .bar{width:100%;border-radius:4px 4px 0 0;min-height:3px;transition:height .35s ease}
    .vbars .b .bv{font-size:10px;font-weight:700;font-variant-numeric:tabular-nums}
    .vbars .b .bl{font-size:9px;color:var(--dim);white-space:nowrap}
  </style>
</head>
<body data-palette="#22c55e,#f59e0b,#3b82f6,#6b7280">
  <header>
    <div class="brand">⚙️ Operations Center<small>Exam delivery overview · administrative &amp; exam sides</small></div>
    <span class="pill" id="healthPill">FastTest: —</span>
    <div class="spacer"></div>
    <span id="clock">--:--:--</span>
  </header>

  <!-- Page-wide subject filter: selecting subjects filters EVERY tile below. -->
  <section class="subjbar">
    <span class="subjbar-lbl">📚 Subjects:</span>
    <div class="fbtns" id="pageFilters"></div>
  </section>

  <section class="kpis">
    <!-- Schools participation -->
    <div class="pgroup">
      <div class="pgl">🏫 Schools Participation</div>
      <div class="pgb">
        <div><div class="pgn" id="pSchP">—</div><div class="pgt">Participating</div></div>
        <div class="pgsep"></div>
        <div><div class="pgn" id="pSchT" style="color:var(--muted)">—</div><div class="pgt">Targeted</div></div>
        <div class="gauge">
          <svg viewBox="0 0 36 36"><circle class="g-bg" cx="18" cy="18" r="15.9155"></circle><circle class="g-fg" id="gSch" cx="18" cy="18" r="15.9155"></circle></svg>
          <span class="gpc" id="pSchR">—</span><span class="gcap">achieved</span>
        </div>
      </div>
    </div>
    <!-- Students participation -->
    <div class="pgroup">
      <div class="pgl">👥 Students Participation</div>
      <div class="pgb">
        <div><div class="pgn" id="pStuP">—</div><div class="pgt">Participating</div></div>
        <div class="pgsep"></div>
        <div><div class="pgn" id="pStuT" style="color:var(--muted)">—</div><div class="pgt">Targeted</div></div>
        <div class="gauge">
          <svg viewBox="0 0 36 36"><circle class="g-bg" cx="18" cy="18" r="15.9155"></circle><circle class="g-fg" id="gStu" cx="18" cy="18" r="15.9155"></circle></svg>
          <span class="gpc" id="pStuR">—</span><span class="gcap">achieved</span>
        </div>
      </div>
    </div>
    <!-- kept exam metrics -->
    <div class="kpi rapid"><div class="l">⚠ Rapid (&lt;2m)</div><div class="v" id="k-rapid">—</div><div class="s" id="k-rapid-pc">needs review</div></div>
  </section>

  <section class="board">
    <div class="tile schools">
      <div class="cap">🏫 Schools by Completion Rate
        <span class="scount" id="schCount"></span>
      </div>
      <div class="schslider">
        <span class="ss-lbl">Show ≤ <b id="schVal">100</b>%</span>
        <input type="range" id="schRange" min="0" max="100" step="5" value="100">
      </div>
      <div class="hlist" id="schools"></div>
    </div>
    <div class="tile funnel">
      <div class="cap">Exam Status Funnel<span class="scount" id="funScope">All subjects</span></div>
      <div id="funnel" style="flex:1;display:flex;flex-direction:column;justify-content:center"></div>
    </div>
    <div class="tile grade">
      <div class="cap">Completion by Grade</div>
      <div class="hlist" id="grades"></div>
    </div>
    <div class="tile subj">
      <div class="cap">Completion by Subject</div>
      <div class="hlist" id="subjects"></div>
    </div>
    <div class="tile time">
      <div class="cap">⏱️ Time &amp; Integrity</div>
      <div class="flag">
        <span class="big" id="t-rapid">—</span>
        <div><div style="font-weight:700;font-size:13px">Rapid completions</div>
          <div class="dim" style="font-size:11.5px" id="t-rapid-sub">finished &lt; 2 min — review</div></div>
      </div>
      <div class="vbars" id="timeDist"></div>
    </div>
  </section>

  <script>
    var fmt=function(n){return (n==null||isNaN(n))?'—':Number(n).toLocaleString('en-US');};
    var pct=function(n,d){return d>0?Math.round(n/d*1000)/10:0;};
    var mmss=function(s){if(s==null||!s)return '—';var m=Math.floor(s/60),x=Math.round(s%60);return m+'m '+(x<10?'0':'')+x+'s';};
    function tick(){document.getElementById('clock').textContent=new Date().toLocaleTimeString('en-GB');}
    setInterval(tick,1000); tick();
    async function j(u){var r=await fetch(u,{headers:{Accept:'application/json'}});if(!r.ok)throw 0;return r.json();}

    function hbars(el,items,colorFn){
      var box=document.getElementById(el);box.innerHTML='';
      items.forEach(function(i){
        var row=document.createElement('div');row.className='hrow';
        row.innerHTML='<span class="nm" title="'+i.l+'">'+i.l+'</span>'+
          '<span class="track"><span style="width:'+i.v+'%;background:'+(colorFn?colorFn(i.v):'linear-gradient(90deg,#16a34a,#22c55e)')+'"></span></span>'+
          '<span class="pc">'+i.v+'%</span>';
        box.appendChild(row);
      });
    }
    function vbars(el,items,color){
      var box=document.getElementById(el);box.innerHTML='';
      var max=Math.max.apply(null,items.map(function(i){return i.v;}).concat([1]));
      // reserve room for the value label above and the axis label below each bar
      var avail=Math.max(24,(box.clientHeight||140)-34);
      items.forEach(function(i){
        var b=document.createElement('div');b.className='b';
        b.innerHTML='<div class="bv">'+(i.v>=1000?Math.round(i.v/1000)+'k':i.v)+'</div>'+
          '<div class="bar" style="height:'+Math.max(3,Math.round(i.v/max*avail))+'px;background:'+(typeof color==='function'?color(i):color)+'" title="'+i.l+': '+fmt(i.v)+'"></div>'+
          '<div class="bl">'+i.l+'</div>';
        box.appendChild(b);
      });
    }
    function completionColor(v){ return v>=80?'linear-gradient(90deg,#16a34a,#22c55e)':v>=50?'linear-gradient(90deg,#d97706,#f59e0b)':'linear-gradient(90deg,#dc2626,#ef4444)'; }
    function gauge(circleId, pctId, pct){
      var c=document.getElementById(circleId), t=document.getElementById(pctId); if(!c) return;
      var col = pct>=90?'#22c55e':pct>=70?'#f59e0b':'#ef4444';
      c.style.stroke=col; c.style.strokeDashoffset=(100-Math.max(0,Math.min(100,pct))).toFixed(1);
      if(t){ t.textContent=pct+'%'; t.style.color=col; }
    }
    var SVGNS='http://www.w3.org/2000/svg';
    function areaChart(el, items){
      var svg=document.getElementById(el); if(!svg||!items.length) return; svg.innerHTML='';
      var W=svg.clientWidth||900, H=svg.clientHeight||180, pL=10,pR=10,pB=20,pT=20;
      svg.setAttribute('viewBox','0 0 '+W+' '+H);
      var vals=items.map(function(i){return i.v;}); var max=Math.max.apply(null,vals)||1; var n=items.length;
      var x=function(i){return pL+(n<2?0.5:i/(n-1))*(W-pL-pR);};
      var y=function(v){return H-pB-(v/max)*(H-pB-pT);};
      var mk=function(t,a){var e=document.createElementNS(SVGNS,t);for(var k in a)e.setAttribute(k,a[k]);return e;};
      var defs=mk('defs',{}); defs.innerHTML='<linearGradient id="dg" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#22c55e" stop-opacity="0.55"/><stop offset="1" stop-color="#22c55e" stop-opacity="0"/></linearGradient>'; svg.appendChild(defs);
      var dA='M'+x(0)+','+(H-pB); items.forEach(function(it,i){dA+=' L'+x(i).toFixed(1)+','+y(it.v).toFixed(1);}); dA+=' L'+x(n-1)+','+(H-pB)+' Z';
      svg.appendChild(mk('path',{d:dA,fill:'url(#dg)'}));
      var dL=''; items.forEach(function(it,i){dL+=(i?' L':'M')+x(i).toFixed(1)+','+y(it.v).toFixed(1);});
      svg.appendChild(mk('path',{d:dL,fill:'none',stroke:'#22c55e','stroke-width':'2.5','stroke-linejoin':'round'}));
      // peak marker + label
      var pi=vals.indexOf(max);
      svg.appendChild(mk('circle',{cx:x(pi),cy:y(max),r:'4',fill:'#22c55e',stroke:'#0a0f1a','stroke-width':'2'}));
      var pt=mk('text',{x:x(pi),y:y(max)-9,fill:'#fff','font-size':'14','font-weight':'800','text-anchor':'middle'}); pt.textContent=(max>=1000?(Math.round(max/100)/10)+'k':max); svg.appendChild(pt);
      // sparse x-axis date labels (~7 ticks)
      var ticks=Math.min(7,n-1);
      for(var t=0;t<=ticks;t++){var i=Math.round(t/ticks*(n-1));var tx=mk('text',{x:x(i),y:H-5,fill:'#8a897f','font-size':'10','text-anchor':(i===0?'start':i===n-1?'end':'middle')});tx.textContent=items[i].l;svg.appendChild(tx);}
    }

    // Schools tile: keep the full list client-side and filter by completion threshold.
    var allSchools = [], schMax = 100;
    function renderSchools(){
      var rows = allSchools.filter(function(s){ return s.completionRate <= schMax; });
      var cnt = document.getElementById('schCount');
      cnt.textContent = rows.length + (schMax<100 ? ' of '+allSchools.length : '') + ' schools';
      if(!rows.length){ document.getElementById('schools').innerHTML='<div class="empty">No schools at or below '+schMax+'% completion. 🎉</div>'; return; }
      hbars('schools', rows.map(function(s){return {l:s.schoolName, v:s.completionRate};}), completionColor);
    }
    (function(){
      var range=document.getElementById('schRange'), val=document.getElementById('schVal');
      range.addEventListener('input', function(){
        schMax = Number(range.value);
        val.textContent = schMax;
        // colour the readout by severity so the threshold reads at a glance
        val.style.color = schMax>=80 ? '#22c55e' : schMax>=50 ? '#f59e0b' : '#ef4444';
        renderSchools();
      });
    })();

    // ---- Exam Status Funnel: multi-select subject filter ----
    // Subject names are long ("parent questions En"), so chips show a short label
    // and keep the full name in the tooltip.
    function shortSubject(name){
      var s=String(name||'—').trim();
      return s
        .replace(/^Arabic\s+Reading$/i,'AR-R').replace(/^Arabic\s+Writing$/i,'AR-W')
        .replace(/^English\s+Reading$/i,'EN-R').replace(/^English\s+Writing$/i,'EN-W')
        .replace(/^Baseline\s+Arabic\s*(\d+)$/i,'BAR$1')
        .replace(/^parent questions\s*En$/i,'PQ-EN').replace(/^parent questions$/i,'PQ')
        .replace(/^Observation form$/i,'OBS')
        .replace(/^Math(ematics)?$/i,'MATH');
    }
    // ---- Page-wide subject filter ----
    // The chip list is built once from the FULL subject list; selecting subjects
    // appends ?examSubjects=... to every fetch so all tiles filter server-side.
    var pageSel = new Set();          // empty = all subjects
    var subjMaster = [];              // full list for the chip bar (never shrinks)

    function qs(){
      if(!pageSel.size) return '';
      return '?examSubjects=' + encodeURIComponent(Array.from(pageSel).join(','));
    }
    function renderPageFilters(){
      var box=document.getElementById('pageFilters');
      var want = subjMaster.join('|');
      if(box.dataset.keys!==want){
        box.dataset.keys=want;
        box.innerHTML='<button type="button" data-all="1">All</button>'+
          subjMaster.map(function(name){
            return '<button type="button" data-s="'+name.replace(/"/g,'&quot;')+'" title="'+name+'">'+shortSubject(name)+'</button>';
          }).join('');
      }
      [].forEach.call(box.children,function(b){
        b.classList.toggle('on', b.dataset.all ? pageSel.size===0 : pageSel.has(b.dataset.s));
      });
    }
    document.getElementById('pageFilters').addEventListener('click', function(e){
      var b=e.target.closest('button'); if(!b) return;
      if(b.dataset.all) pageSel.clear();
      else if(pageSel.has(b.dataset.s)) pageSel.delete(b.dataset.s);
      else pageSel.add(b.dataset.s);
      renderPageFilters();
      refresh(); // re-fetch every tile with the new subject filter
    });
    function renderFunnel(subjects){
      var agg = (subjects||[]).reduce(function(a,s){
        a.total+=s.total||0; a.ns+=(s.NOT_STARTED||0)+(s.NOT_SYNCED||0); a.ip+=s.IN_PROGRESS||0; a.co+=s.COMPLETED||0; return a;
      },{total:0,ns:0,ip:0,co:0});
      document.getElementById('funScope').textContent =
        (pageSel.size ? pageSel.size+' subject'+(pageSel.size>1?'s':'') : 'All subjects')+' · '+fmt(agg.total);
      var stages=[
        {nm:'Not Started', v:agg.ns, c:'linear-gradient(90deg,#2563eb,#3b82f6)'},
        {nm:'In Progress', v:agg.ip, c:'linear-gradient(90deg,#d97706,#f59e0b)'},
        {nm:'Completed',   v:agg.co, c:'linear-gradient(90deg,#16a34a,#22c55e)'}
      ];
      document.getElementById('funnel').innerHTML = stages.map(function(s){
        var w=agg.total>0?(s.v/agg.total*100):0;
        return '<div class="fstage"><div class="fh"><span class="muted">'+s.nm+'</span><b>'+fmt(s.v)+' <span class="dim" style="font-size:12px">'+pct(s.v,agg.total)+'%</span></b></div>'+
          '<div class="fbar"><span style="width:'+w+'%;background:'+s.c+'"></span></div></div>';
      }).join('');
    }

    // One-time fetch of the full subject list to populate the filter chips.
    async function loadSubjectChips(){
      try{
        var r = await j('/api/dashboard/subjects');
        subjMaster = (r.subjects||[]).slice().sort(function(a,b){return b.total-a.total;}).map(function(s){return s.examSubject;});
        renderPageFilters();
      }catch(e){}
    }

    async function refresh(){
      try{
        var q = qs();
        var ov, schools, subj, grades, exam, part;
        [ov, schools, subj, grades, exam, part] = await Promise.all([
          j('/api/dashboard/overview'+q),
          j('/api/dashboard/schools'+q).catch(function(){return {schools:[]};}),
          j('/api/dashboard/subjects'+q).catch(function(){return {subjects:[]};}),
          j('/api/dashboard/completion-by-grade'+q).catch(function(){return {grades:[]};}),
          j('/api/dashboard/exam-analytics'+q).catch(function(){return null;}),
          j('/api/dashboard/participation'+q).catch(function(){return null;})
        ]);

        var sc = schools.schools||[];
        // Participation: targeted vs participating + achieved gauge
        if (part) {
          document.getElementById('pSchP').textContent=fmt(part.schools.participating);
          document.getElementById('pSchT').textContent='of '+fmt(part.schools.targeted);
          document.getElementById('pStuP').textContent=fmt(part.students.participating);
          document.getElementById('pStuT').textContent='of '+fmt(part.students.targeted);
          gauge('gSch','pSchR',part.schools.rate);
          gauge('gStu','pStuR',part.students.rate);
        }
        var rapid=exam&&exam.time?exam.time.rapidCount:0, rtot=exam&&exam.time?exam.time.total:0;
        document.getElementById('k-rapid').textContent=fmt(rapid);
        document.getElementById('k-rapid-pc').textContent=(rtot>0?Math.round(rapid/rtot*1000)/10:0)+'% of completed';

        allSchools = sc.filter(function(s){return s.total>0;}).sort(function(a,b){return a.completionRate-b.completionRate;});
        renderSchools();

        hbars('subjects', (subj.subjects||[]).slice().sort(function(a,b){return b.total-a.total;}).map(function(s){return {l:s.examSubject, v:s.completionRate!=null?s.completionRate:pct(s.COMPLETED,s.total)};}), completionColor);

        hbars('grades', (grades.grades||[]).map(function(g){var gr=String(g.grade||'—');return {l:/grade/i.test(gr)?gr:'Grade '+gr, v:g.completionRate};}), completionColor);

        renderFunnel((subj.subjects||[]));

        if(exam && exam.time){
          document.getElementById('t-rapid').textContent=fmt(exam.time.rapidCount);
          document.getElementById('t-rapid-sub').textContent='of '+fmt(exam.time.total)+' · '+pct(exam.time.rapidCount,exam.time.total)+'% · avg '+Math.round((exam.time.avgSeconds||0)/60)+'m/exam';
          vbars('timeDist', (exam.time.distribution||[]).map(function(b){return {l:b.label, v:b.count};}),
            function(i){return i.l==='<2m'?'linear-gradient(180deg,#ef4444,#dc2626)':'linear-gradient(180deg,#4c8dff,#9b7be8)';});
        }
      }catch(e){}
    }
    async function refreshHealth(){
      try{ var h=await j('/api/fasttest/health');
        var hp=document.getElementById('healthPill');
        var icon=h.verdict==='HEALTHY'?'🟢':(h.verdict==='DEGRADED'?'🟡':'🔴');
        hp.textContent=icon+' FastTest: '+h.verdict; hp.style.color=h.verdict==='HEALTHY'?'#22c55e':(h.verdict==='DEGRADED'?'#f59e0b':'#ef4444');
      }catch(e){}
    }
    loadSubjectChips(); refresh(); refreshHealth();
    setInterval(refresh, 6000); setInterval(refreshHealth, 8000);
  </script>
</body>
</html>
