<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Operations Center — Live</title>
  <style>
    :root{
      --bg:#080a0f; --card:#11141c; --card2:#141824; --line:#212636; --ink:#eef1f8; --muted:#9aa0b4; --dim:#666c82;
      --good:#26c281; --warn:#f0b429; --bad:#e05260; --info:#4c8dff; --violet:#9b7be8;
    }
    *{box-sizing:border-box;margin:0;padding:0}
    html,body{height:100%}
    body{background:radial-gradient(900px 500px at 0% -10%, #12182a 0%, transparent 55%), var(--bg);
      color:var(--ink);font-family:"Segoe UI",-apple-system,BlinkMacSystemFont,Roboto,Helvetica,Arial,sans-serif;
      overflow:hidden;display:flex;flex-direction:column;height:100vh;padding:16px 18px;gap:12px;-webkit-font-smoothing:antialiased}
    .muted{color:var(--muted)}.dim{color:var(--dim)}
    header{display:flex;align-items:center;gap:14px;flex:0 0 auto}
    .htitle{font-size:21px;font-weight:800;letter-spacing:.3px}
    .htitle .ic{margin-right:8px}
    header .spacer{flex:1}
    .pill{display:inline-flex;align-items:center;gap:8px;padding:6px 13px;border-radius:999px;font-size:13px;font-weight:700;border:1px solid var(--line);background:var(--card)}
    .pill .d{width:9px;height:9px;border-radius:50%}
    .pulse{animation:pulse 1.6s infinite}@keyframes pulse{0%,100%{opacity:1}50%{opacity:.35}}
    #clock{font-variant-numeric:tabular-nums;font-size:21px;font-weight:700}
    /* status tiles */
    .tiles{display:grid;grid-template-columns:repeat(8,1fr);gap:10px;flex:0 0 auto}
    .tile{background:linear-gradient(180deg,var(--card2),var(--card));border:1px solid var(--line);border-radius:14px;padding:12px 14px;position:relative;overflow:hidden}
    .tile .l{font-size:11px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.5px}
    .tile .v{font-size:clamp(22px,2.6vw,34px);font-weight:800;margin-top:5px;font-variant-numeric:tabular-nums;line-height:1}
    .tile .s{font-size:11px;color:var(--dim);margin-top:3px}
    .tile.ok .v{color:var(--good)} .tile.warn .v{color:var(--warn)} .tile.bad .v{color:var(--bad)} .tile.info .v{color:var(--info)}
    /* progress */
    .progress{background:linear-gradient(180deg,var(--card2),var(--card));border:1px solid var(--line);border-radius:14px;padding:14px 18px;flex:0 0 auto}
    .progress .top{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:9px}
    .progress .top .t{font-size:13px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.6px}
    .progress .top .n{font-size:15px;font-weight:700}
    .pbar{height:16px;background:#0a0c12;border-radius:9px;overflow:hidden}
    .pbar>span{display:block;height:100%;background:linear-gradient(90deg,#26c281,#4c8dff);border-radius:9px;transition:width .8s cubic-bezier(.2,.8,.2,1)}
    /* grid */
    .grid{flex:1 1 auto;display:grid;grid-template-columns:1fr 1.4fr 1fr;grid-template-rows:1fr auto;gap:12px;min-height:0}
    .panel{background:linear-gradient(180deg,var(--card2),var(--card));border:1px solid var(--line);border-radius:14px;padding:14px 16px;display:flex;flex-direction:column;min-height:0}
    .panel h3{font-size:12px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;display:flex;align-items:center;gap:8px;flex:0 0 auto}
    .panel .body{flex:1;min-height:0;overflow:auto}
    .wide{grid-column:1 / -1}
    /* health rows */
    .hrow{display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid var(--line);font-size:14px}
    .hrow:last-child{border-bottom:none}
    .hrow b{font-size:17px;font-variant-numeric:tabular-nums}
    .lat{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:8px}
    .lat .m{background:#0a0c12;border-radius:9px;padding:9px;text-align:center}
    .lat .m .v{font-size:19px;font-weight:800;font-variant-numeric:tabular-nums} .lat .m .l{font-size:10px;color:var(--dim);text-transform:uppercase}
    .gauge{height:11px;background:#0a0c12;border-radius:7px;overflow:hidden;margin-top:6px}
    .gauge>span{display:block;height:100%;border-radius:7px;transition:width .6s}
    /* chart */
    svg.line{width:100%;height:100%}
    /* queue bars */
    .qbar{margin:9px 0}
    .qbar .top{display:flex;justify-content:space-between;font-size:13.5px;margin-bottom:4px}
    .qbar .top b{font-variant-numeric:tabular-nums}
    .qbar .track{height:11px;background:#0a0c12;border-radius:6px;overflow:hidden}
    .qbar .track>span{display:block;height:100%;border-radius:6px}
    /* errors */
    table.err{width:100%;font-size:12.5px;border-collapse:collapse}
    table.err td{padding:5px 8px;border-bottom:1px solid var(--line)}
    .chip{padding:2px 8px;border-radius:6px;font-weight:700;font-size:11px;background:#e0526022;color:#e05260}
  </style>
</head>
<body>
  <header>
    <div class="htitle"><span class="ic">⚙️</span>Operations Center</div>
    <span class="pill" id="engine"><span class="d pulse" style="background:var(--good)"></span>Engine —</span>
    <span class="pill" id="mode">Mode —</span>
    <div class="spacer"></div>
    <span class="pill" id="upd">live</span>
    <div id="clock">--:--:--</div>
  </header>

  <section class="tiles">
    <div class="tile ok"><div class="l">Throughput</div><div class="v" id="t-tput">—</div><div class="s">jobs / min</div></div>
    <div class="tile info"><div class="l">Queued</div><div class="v" id="t-queued">—</div><div class="s" id="t-oldest">—</div></div>
    <div class="tile warn"><div class="l">Running</div><div class="v" id="t-running">—</div><div class="s">active now</div></div>
    <div class="tile"><div class="l">Retry</div><div class="v" id="t-retry">—</div><div class="s">scheduled</div></div>
    <div class="tile bad"><div class="l">Dead-letter</div><div class="v" id="t-dead">—</div><div class="s">needs action</div></div>
    <div class="tile"><div class="l">Not Synced</div><div class="v" id="t-notsynced">—</div><div class="s">remaining</div></div>
    <div class="tile"><div class="l">Failed / min</div><div class="v" id="t-failed">—</div><div class="s">last minute</div></div>
    <div class="tile ok"><div class="l">Circuit</div><div class="v" id="t-circuit" style="font-size:22px">—</div><div class="s" id="t-api">—</div></div>
  </section>

  <div class="progress">
    <div class="top"><span class="t">Sync Progress</span><span class="n" id="p-txt">—</span></div>
    <div class="pbar"><span id="p-bar" style="width:0%"></span></div>
  </div>

  <section class="grid">
    <div class="panel">
      <h3>🩺 FastTest Health</h3>
      <div class="body">
        <div class="hrow"><span class="muted">Status</span><b id="h-verdict">—</b></div>
        <div class="hrow"><span class="muted">Success rate</span><b id="h-success">—</b></div>
        <div class="hrow"><span class="muted">Calls / min</span><b id="h-cpm">—</b></div>
        <div class="lat">
          <div class="m"><div class="v" id="h-p50">—</div><div class="l">p50</div></div>
          <div class="m"><div class="v" id="h-p95">—</div><div class="l">p95</div></div>
          <div class="m"><div class="v" id="h-p99">—</div><div class="l">p99</div></div>
        </div>
        <div style="margin-top:12px"><span class="muted" style="font-size:12px">Rate utilization <span id="h-rate" class="dim"></span></span><div class="gauge"><span id="h-rateb" style="width:0%;background:var(--info)"></span></div></div>
      </div>
    </div>

    <div class="panel">
      <h3>📈 Throughput — last 30 min</h3>
      <svg class="line" id="chart" viewBox="0 0 600 200" preserveAspectRatio="none"></svg>
    </div>

    <div class="panel">
      <h3>📦 Queue Breakdown</h3>
      <div class="body" id="queue"></div>
    </div>

    <div class="panel wide">
      <h3>⚠️ Recent Errors <span class="dim" id="err-n"></span></h3>
      <div class="body"><table class="err"><tbody id="err-body"></tbody></table></div>
    </div>
  </section>

  <script>
    var fmt=function(n){return (n==null||isNaN(n))?'—':Number(n).toLocaleString('en-US');};
    var ago=function(iso){if(!iso)return '—';var s=Math.max(0,(Date.now()-new Date(iso).getTime())/1000);return s<60?Math.round(s)+'s':s<3600?Math.round(s/60)+'m':Math.round(s/3600)+'h';};
    function tick(){document.getElementById('clock').textContent=new Date().toLocaleTimeString('en-GB');}
    setInterval(tick,1000);tick();
    async function j(u){var r=await fetch(u,{headers:{Accept:'application/json'}});if(!r.ok)throw 0;return r.json();}
    function set(id,v){var e=document.getElementById(id);if(e)e.textContent=v;}
    function tileClass(id,cls){var e=document.getElementById(id);if(e){e.className='tile '+cls;}}

    function lineChart(series){
      var svg=document.getElementById('chart');svg.innerHTML='';var W=600,H=200,p=6;
      var pts=(series||[]).map(function(s){return s.count||0;});
      if(pts.length<2)return;
      var max=Math.max.apply(null,pts)||1;
      var x=function(i){return p+i/(pts.length-1)*(W-2*p);},y=function(v){return H-p-v/max*(H-2*p);};
      var area='M'+x(0)+','+(H-p);pts.forEach(function(v,i){area+=' L'+x(i).toFixed(1)+','+y(v).toFixed(1);});area+=' L'+x(pts.length-1)+','+(H-p)+' Z';
      var a=document.createElementNS('http://www.w3.org/2000/svg','path');a.setAttribute('d',area);a.setAttribute('fill','#26c281');a.setAttribute('opacity','.13');svg.appendChild(a);
      var d='';pts.forEach(function(v,i){d+=(i?' L':'M')+x(i).toFixed(1)+','+y(v).toFixed(1);});
      var l=document.createElementNS('http://www.w3.org/2000/svg','path');l.setAttribute('d',d);l.setAttribute('fill','none');l.setAttribute('stroke','#26c281');l.setAttribute('stroke-width','2.5');l.setAttribute('vector-effect','non-scaling-stroke');svg.appendChild(l);
    }

    async function load(){
      try{
        var qs,health,ctrl,ov;
        [qs,health,ctrl,ov]=await Promise.all([
          j('/api/queue/stats'), j('/api/fasttest/health').catch(function(){return null;}),
          j('/api/queue/control-state').catch(function(){return null;}), j('/api/dashboard/overview').catch(function(){return null;})
        ]);
        set('upd','updated '+new Date().toLocaleTimeString('en-GB'));

        // engine + mode pills
        var eng=document.getElementById('engine'), md=document.getElementById('mode');
        if(ctrl){
          if(ctrl.globalPaused){ eng.innerHTML='<span class="d" style="background:var(--bad)"></span>Engine OFF'; }
          else if(!ctrl.allowedNow){ eng.innerHTML='<span class="d" style="background:var(--warn)"></span>Outside window'; }
          else { eng.innerHTML='<span class="d pulse" style="background:var(--good)"></span>Engine ON'; }
          md.textContent = ctrl.fastMode ? 'Mode: ⚡ FAST' : 'Mode: Normal';
        }

        // status tiles
        set('t-tput', fmt(qs.jobsLastMin));
        set('t-queued', fmt(qs.queued));
        set('t-oldest', qs.oldestQueuedAgeMs!=null ? 'oldest '+Math.round(qs.oldestQueuedAgeMs/1000)+'s' : '');
        set('t-running', fmt(qs.running));
        set('t-retry', fmt(qs.retryScheduled));
        set('t-dead', fmt(qs.deadLetter));
        tileClass('t-dead', (qs.deadLetter||0)>0?'tile bad':'tile');
        if(ov) set('t-notsynced', fmt(ov.NOT_SYNCED));
        if(health){
          set('t-circuit', health.workspace?health.workspace.circuit:'—');
          tileClass('t-circuit', (health.workspace&&health.workspace.circuit==='CLOSED')?'tile ok':'tile bad');
          set('t-api', (health.calls?health.calls.successRate+'% API':''));
        }

        // sync progress
        if(ov){
          var total=ov.totalRegistered||0, synced=total-(ov.NOT_SYNCED||0), p=total>0?Math.round(synced/total*1000)/10:0;
          document.getElementById('p-bar').style.width=p+'%';
          set('p-txt', p+'%  ·  '+fmt(synced)+' / '+fmt(total)+' synced');
        }

        // FastTest health panel
        if(health){
          var col=health.verdict==='HEALTHY'?'var(--good)':(health.verdict==='DEGRADED'?'var(--warn)':'var(--bad)');
          var hv=document.getElementById('h-verdict');hv.textContent=health.verdict;hv.style.color=col;
          set('h-success', (health.calls?health.calls.successRate+'%':'—'));
          set('h-cpm', fmt(health.calls?health.calls.callsLastMin:0));
          set('h-p50', (health.latency?health.latency.p50:'—')+'ms');
          set('h-p95', (health.latency?health.latency.p95:'—')+'ms');
          set('h-p99', (health.latency?health.latency.p99:'—')+'ms');
          var ru=health.throughput?health.throughput.rateUtil:0;
          var g=document.getElementById('h-rateb');g.style.width=ru+'%';g.style.background=ru>90?'var(--bad)':ru>70?'var(--warn)':'var(--info)';
          set('h-rate', (health.throughput?health.throughput.currentRps+'/'+health.throughput.maxRps+' rps ('+ru+'%)':''));
          lineChart(health.timeSeries);
          // workers approximate from health? use queue running / just show from qs
        }

        set('t-failed', fmt(qs.failedLastMin||0));
        tileClass('t-failed', (qs.failedLastMin||0)>0?'tile bad':'tile');

        // queue breakdown bars
        var qb=document.getElementById('queue');qb.innerHTML='';
        var parts=[
          {nm:'Queued',v:qs.queued||0,c:'#4c8dff'},
          {nm:'Running',v:qs.running||0,c:'#f0b429'},
          {nm:'Retry scheduled',v:qs.retryScheduled||0,c:'#9b7be8'},
          {nm:'Dead-letter',v:qs.deadLetter||0,c:'#e05260'},
          {nm:'Completed',v:qs.completed||0,c:'#26c281'}
        ];
        var qmax=Math.max.apply(null,parts.map(function(p){return p.v;}).concat([1]));
        parts.forEach(function(p){
          var row=document.createElement('div');row.className='qbar';
          row.innerHTML='<div class="top"><span>'+p.nm+'</span><b>'+fmt(p.v)+'</b></div><div class="track"><span style="width:'+Math.max(1,p.v/qmax*100)+'%;background:'+p.c+'"></span></div>';
          qb.appendChild(row);
        });

        // recent errors
        var eb=document.getElementById('err-body');eb.innerHTML='';
        var errs=(health&&health.recentErrors)?health.recentErrors.slice(0,12):[];
        set('err-n','('+errs.length+')');
        if(!errs.length){ eb.innerHTML='<tr><td class="muted" style="padding:12px">No recent errors ✓</td></tr>'; }
        errs.forEach(function(e){
          var tr=document.createElement('tr');
          tr.innerHTML='<td class="dim" style="white-space:nowrap">'+ago(e.at)+' ago</td><td class="muted">'+(e.endpoint||'')+'</td>'+
            '<td><span class="chip">'+(e.httpStatus||'timeout')+'</span></td><td class="dim">'+((e.message||'').substring(0,70)||'—')+'</td>';
          eb.appendChild(tr);
        });
      }catch(e){}
    }
    load(); setInterval(load,4000);
  </script>
</body>
</html>
